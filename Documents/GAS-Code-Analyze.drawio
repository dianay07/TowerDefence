        <mxCell id="nYRWSuvBfACys_Zh3A_y-30" parent="1" style="whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#00CC66;gradientColor=none;rounded=0;" value="&lt;div&gt;UGameplayCueManager::HandleGameplayCue&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;void UGameplayCueManager::TranslateGameplayCue(FGameplayTag&amp;amp; Tag, AActor* TargetActor, const FGameplayCueParameters&amp;amp; Parameters)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;TranslationManager.TranslateTag(Tag, TargetActor, Parameters);&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;초기화 &amp;amp; 로딩 관리 하는 것으로 보임.&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&#x9;&lt;/span&gt;RuntimeGameplayCueObjectLibrary.CueSet-&amp;gt;HandleGameplayCue(TargetActor, GameplayCueTag, EventType, Parameters);&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;Tag 단위로 처리 하는 것으로 보임.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Tag 에 연결된 Function List 를 수집해서 호출 하는 로직이 있음.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
