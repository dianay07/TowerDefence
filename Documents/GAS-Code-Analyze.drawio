        <mxCell id="nYRWSuvBfACys_Zh3A_y-39" parent="1" style="ellipse;whiteSpace=wrap;html=1;" value="ASC 를 인터페이스를 통해&lt;div&gt;ASC를 Effect Context 에 연결&lt;/div&gt;" vertex="1">
