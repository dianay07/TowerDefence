        <mxCell id="nYRWSuvBfACys_Zh3A_y-29" value="&amp;nbsp;UAbilitySystemComponent::InvokeGameplayCueEvent(const FGameplayEffectSpecForRPC &amp;amp;Spec, EGameplayCueEvent::Type EventType)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;for (FGameplayEffectCue CueInfo : Spec.Def-&amp;gt;GameplayCues)&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;UAbilitySystemGlobals::Get().GetGameplayCueManager()&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;-&amp;gt;HandleGameplayCues(ActorAvatar, CueInfo.GameplayCueTags, EventType, CueParameters);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#00CC66;gradientColor=none;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="1025" y="1560" width="560" height="210" as="geometry" />
        </mxCell>
        <mxCell id="nYRWSuvBfACys_Zh3A_y-30" value="&lt;div&gt;UGameplayCueManager::HandleGameplayCue&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;void UGameplayCueManager::TranslateGameplayCue(FGameplayTag&amp;amp; Tag, AActor* TargetActor, const FGameplayCueParameters&amp;amp; Parameters)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;TranslationManager.TranslateTag(Tag, TargetActor, Parameters);&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;초기화 &amp;amp; 로딩 관리 하는 것으로 보임.&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&#x9;&lt;/span&gt;RuntimeGameplayCueObjectLibrary.CueSet-&amp;gt;HandleGameplayCue(TargetActor, GameplayCueTag, EventType, Parameters);&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;Tag 단위로 처리 하는 것으로 보임.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Tag 에 연결된 Function List 를 수집해서 호출 하는 로직이 있음.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#00CC66;gradientColor=none;rounded=0;" parent="1" vertex="1">
