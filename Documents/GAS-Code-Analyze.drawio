        <mxCell id="nYRWSuvBfACys_Zh3A_y-29" parent="1" style="whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#00CC66;gradientColor=none;rounded=0;" value="&amp;nbsp;UAbilitySystemComponent::InvokeGameplayCueEvent(const FGameplayEffectSpecForRPC &amp;amp;Spec, EGameplayCueEvent::Type EventType)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;for (FGameplayEffectCue CueInfo : Spec.Def-&amp;gt;GameplayCues)&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;UAbilitySystemGlobals::Get().GetGameplayCueManager()&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;-&amp;gt;HandleGameplayCues(ActorAvatar, CueInfo.GameplayCueTags, EventType, CueParameters);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
