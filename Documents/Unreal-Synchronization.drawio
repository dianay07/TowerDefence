        <mxCell id="7kC43H_nsfkWkIT92Jpe-47" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;실제로는 3d 좌표를 PolarToCartesian 함수를 통해 직교 좌표계로 변경한다.&lt;/span&gt;&lt;/div&gt;" vertex="1">
