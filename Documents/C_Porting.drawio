        <mxCell id="sbMdM6gBOHIMnYuIiBfh-35" value="ATDPlayerController::HandleClick()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="710" y="4800" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="sbMdM6gBOHIMnYuIiBfh-36" value="클릭에 대한 함수 Bind , TowerBase 있는 Cick 관련 내용이 이동" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="995" y="4800" width="205" height="60" as="geometry" />
        </mxCell>
        <mxCell id="sbMdM6gBOHIMnYuIiBfh-38" value="내부에서 사용하는 로직 관리 목적&lt;br&gt;InitSlot,&amp;nbsp;RefreshSlot , Tower 데이터를 가지고 사용할때 좋음.&lt;div&gt;기존에 작동방식은 유지 하기 위해 Slot 을 담을 수 있는 객체는 있지만 삭제 가능&lt;br&gt;BP 에서 각 타입별로&amp;nbsp; Slot 에 대한 초기화 진행&lt;/div&gt;&lt;div&gt;인게임에서 사용할 버튼 클릭시 나오는 이미지 생성 함수가&lt;/div&gt;&lt;div&gt;BP 함수인것으로 보여서 모두 가져갈 수 없었음.&lt;/div&gt;" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="4935" width="326.5" height="130" as="geometry" />
